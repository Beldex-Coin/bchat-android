<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context="io.beldex.bchat.conversation.v2.ConversationActivityV2">

    <LinearLayout
        android:id="@+id/contentView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?colorPrimary"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/conversationActivity_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?colorPrimary">

            <ImageButton
                android:id="@+id/back_to_home_Btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@android:color/transparent"
                android:padding="3dp"
                android:src="@drawable/ic_back_arrow" />

            <LinearLayout
                android:id="@+id/layout_conversation"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <include
                    android:id="@+id/profilePictureView"
                    layout="@layout/view_profile_picture"
                    android:layout_width="@dimen/medium_profile_picture_size"
                    android:layout_height="@dimen/medium_profile_picture_size" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/conversationTitleView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="User"
                        android:textColor="@color/text"
                        android:textSize="@dimen/medium_font_size"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"

                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/muteIconImageView"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:layout_marginEnd="4dp"
                            android:alpha="0.6"
                            android:src="@drawable/ic_outline_notifications_off_24"
                            android:visibility="gone"
                            app:tint="@color/text"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/conversationSubtitleView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.6"
                            android:ellipsize="end"
                            android:fontFamily="@font/open_sans_regular"
                            android:maxLines="1"
                            android:text="Muted"
                            android:textColor="@color/text"
                            android:textSize="@dimen/very_small_font_size" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:layout_marginHorizontal="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/search_background"
            app:cardCornerRadius="32dp"
            app:contentPadding="12dp"
            app:strokeColor="@color/search_background_border"
            app:strokeWidth="1dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/search"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?selectableItemBackgroundBorderless"
                        android:padding="4dp"
                        android:src="@drawable/ic_baseline_search_24"
                        android:tint="#A7A7BA"
                        tools:ignore="UseAppTint" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/search_query"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Search"
                        android:imeOptions="actionDone"
                        android:longClickable="false"
                        android:singleLine="true"
                        android:textColorHint="#A7A7BA"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp" />

                    <ImageView
                        android:id="@+id/searchDown"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center_vertical"
                        android:background="?selectableItemBackgroundBorderless"
                        android:padding="4dp"
                        android:src="@drawable/ic_down"
                        android:tint="@color/accent"
                        android:visibility="gone"
                        tools:ignore="UseAppTint" />

                    <ImageView
                        android:id="@+id/searchUp"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?selectableItemBackgroundBorderless"
                        android:padding="4dp"
                        android:src="@drawable/ic_up"
                        android:tint="@color/accent"
                        android:visibility="gone"
                        tools:ignore="UseAppTint" />

                    <ImageView
                        android:id="@+id/close_search"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?selectableItemBackgroundBorderless"
                        android:padding="4dp"
                        android:src="@drawable/ic_close"
                        android:tint="@color/red"
                        android:visibility="gone"
                        tools:ignore="UseAppTint" />

                    <ImageView
                        android:id="@+id/searchClose"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?selectableItemBackgroundBorderless"
                        android:padding="4dp"
                        android:src="@drawable/ic_search_close_circle"
                        android:tint="#A7A7BA"
                        tools:ignore="UseAppTint" />

                    <ProgressBar
                        android:id="@+id/search_progress"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/noMatchesFoundTextview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:layout_marginTop="5dp"
                    android:text="No Matches found!"
                    android:textColor="@color/text"
                    android:textSize="@dimen/very_small_font_size"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/callActionBarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:background="@color/button_green"
            android:orientation="vertical"
            android:padding="10dp">

            <RelativeLayout
                android:id="@+id/bchat_toolbar_Call"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/callDuration_Call"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="20dp"
                    android:fontFamily="@font/open_sans_bold"
                    android:gravity="center_vertical"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="@tools:sample/date/hhmmss" />

                <TextView
                    android:id="@+id/callInProgress_Call"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="10dp"
                    android:layout_toEndOf="@id/callDuration_Call"
                    android:fontFamily="@font/open_sans_bold"
                    android:text="@string/call_in_progress"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/hanUp_Call"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_end_call_home" />

            </RelativeLayout>
        </LinearLayout>
