                <!--            </LinearLayout>-->

                <RelativeLayout
                    android:id="@+id/scrollToBottomButton"
                    android:layout_width="30dp"
                    android:layout_height="40dp"
                    android:layout_alignWithParentIfMissing="true"
                    android:layout_above="@+id/inputBar"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="32dp"
                    android:visibility="gone">

                    <RelativeLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:background="@drawable/view_scroll_to_bottom_button_background">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerInParent="true"
                            android:src="@drawable/ic_down" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/unreadCountIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_centerHorizontal="true"
                        android:background="@drawable/rounded_rectangle"
                        android:backgroundTint="@color/conversation_unread_count_indicator_background"
                        android:maxWidth="40dp"
                        android:paddingLeft="4dp"
                        android:paddingRight="4dp">

                        <TextView
                            android:id="@+id/unreadCountTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="@dimen/very_small_font_size"
                            android:textStyle="bold"
                            android:minHeight="18dp"
                            android:minWidth="18dp"/>

                    </RelativeLayout>

                </RelativeLayout>

                <io.beldex.bchat.conversation.v2.input_bar.InputBarRecordingView
                    android:id="@+id/inputBarRecordingView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    android:elevation="5dp"
                    android:visibility="gone" />


                <LinearLayout
                    android:id="@+id/networkStatusLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/page_background"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/connectedStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="5dp"
                        android:layout_marginBottom="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:textAlignment="center"
                        android:textColor="@color/text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/networkStatusImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_connected" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/blockedBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:background="@color/page_background"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/received_message_background"
                        android:clickable="false"
                        android:enabled="false"
                        android:fontFamily="@font/open_sans_regular"
                        android:padding="8dp"
                        android:text="@string/blocked_user_message"
                        android:textAllCaps="false"
                        android:textColor="@color/received_quoted_text_color"
                        android:textSize="12sp"
                        app:cornerRadius="24dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clear_chat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/receive_payment_card_background"
                            android:fontFamily="@font/open_sans_semi_bold"
                            android:gravity="center"
                            android:padding="16dp"
                            android:text="@string/clear_chat"
                            android:textAllCaps="false"
                            android:textColor="@color/clear_red_color"
                            android:textSize="14sp"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_clear_conversation"
                            app:iconGravity="textStart"
                            app:iconTint="@color/clear_red_color" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/unblockButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/bchat_id_text_color"
                            android:fontFamily="@font/open_sans_semi_bold"
                            android:gravity="center"
                            android:padding="16dp"
                            android:text="@string/ConversationActivity_unblock"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_unblock_user"
                            app:iconGravity="textStart"
                            app:iconTint="@color/white" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/messageRequestBarCardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_above="@id/inputBar"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="15dp"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/missed_call_dialog_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/message_request_view_border"
                    app:strokeWidth="1dp"
                    tools:visibility="gone">

                    <LinearLayout
                        android:id="@+id/messageRequestBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_above="@id/inputBar"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="15dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="15dp"
                        android:layout_marginBottom="10dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:ignore="NotSibling"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/messageRequestTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/small_spacing"
                            android:fontFamily="@font/open_sans_bold"
                            android:paddingHorizontal="@dimen/massive_spacing"
                            android:text="@string/message_request"
                            android:textColor="@color/text"
                            android:textSize="16sp"
                            android:visibility="visible" />

                        <TextView
                            android:id="@+id/messageRequestBlock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/open_sans_bold"
                            android:paddingHorizontal="@dimen/massive_spacing"
                            android:paddingVertical="@dimen/small_spacing"
                            android:text="@string/activity_conversation_block_user"
                            android:textColor="@color/negative_red_button_border"
                            android:textSize="@dimen/text_size"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/sendAcceptsTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/medium_spacing"
                            android:alpha="0.6"
                            android:fontFamily="@font/open_sans_regular"
                            android:gravity="center_horizontal"
                            android:text="@string/message_requests_send_notice"
                            android:textColor="@color/text"
                            android:textSize="@dimen/small_font_size" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/declineMessageRequestButton"
                                style="@style/Widget.Bchat.Button.Dialog.Cancel"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/open_sans_regular"
                                android:text="@string/decline"
                                android:textColor="@color/negative_green_button_text"
                                android:textSize="14sp" />

                            <Button
                                android:id="@+id/acceptMessageRequestButton"
                                style="@style/Widget.Bchat.Button.Dialog.Enable"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_marginStart="@dimen/small_spacing"
                                android:layout_weight="1"
                                android:fontFamily="@font/open_sans_regular"
                                android:text="@string/accept"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <io.beldex.bchat.util.slidetoact.SlideToActView
                    android:id="@+id/slideToPayButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_above="@id/inputBar"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="70dp"
                    android:layout_marginEnd="70dp"
                    android:layout_marginBottom="70dp"
                    android:visibility="gone"
                    app:area_margin="8dp"
                    app:icon_margin="0dp"
                    app:image_color="@color/cancel_button_text"
                    app:inner_color="@color/cancel_button_text"
                    app:outer_color="@color/input_bar_background"
                    app:send_icon_margin="12dp"
                    app:slider_height="50dp"
                    app:slider_icon_color="@color/text"
                    app:slider_locked="false"
                    app:text="@string/swipe_to_send_bdx"
                    app:text_size="14sp" />

            </RelativeLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/additionalContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/reactions_shade"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/reactions_screen_light_shade_color"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@color/reactions_screen_dark_shade_color"
        android:visibility="gone"
        tools:visibility="visible" />

    <ViewStub
        android:id="@+id/conversation_reaction_scrubber_stub"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inflatedId="@+id/conversation_reaction_scrubber"
        android:layout="@layout/conversation_reaction_scrubber" />
</RelativeLayout>

